{
  "name": "devcontainer",
  "image": "ghcr.io/mrsimonemms/devcontainers/full",
  "features": {
    "ghcr.io/dhoeric/features/trivy:1": {},
    "ghcr.io/mrsimonemms/devcontainers/cobra-cli:1": {},
    "ghcr.io/devcontainers-extra/features/gh-release:1": {
      "repo": "goreleaser/goreleaser",
      "binaryNames": "goreleaser",
      "assetRegex": "goreleaser_Linux_.*\\.tar\\.gz$"
    },
    "ghcr.io/devcontainers-extra/features/temporal-cli:1": {},
    "ghcr.io/va-h/devcontainers-features/uv:1": {
      "shellautocompletion": true
    },
    "ghcr.io/azutake/devcontainer-features/go-packages-install:0": {
      "PACKAGES": "github.com/cosmtrek/air@latest,google.golang.org/protobuf/cmd/protoc-gen-go@latest,google.golang.org/grpc/cmd/protoc-gen-go-grpc@latest"
    },
    "ghcr.io/devcontainers-extra/features/protoc:1": {},
    "ghcr.io/mrsimonemms/devcontainers/buf:1": {},
    "ghcr.io/devcontainers-extra/features/grpcurl-asdf:2": {},
    "ghcr.io/rio/features/skaffold:2": {},
    "ghcr.io/devcontainers-extra/features/go-task:1": {}
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "esbenp.prettier-vscode",
        "unifiedjs.vscode-mdx",
        "DrBlury.protobuf-vsc"
      ],
      "settings": {}
    }
  },
  "postCreateCommand": {
    "go-generate": "go generate ./...",
    "helm-plugin-unittest": "helm plugin install --verify=false https://github.com/helm-unittest/helm-unittest",
    "install-air": "go install github.com/air-verse/air@latest",
    "task-completion": "task --completion bash | sudo tee -a /etc/bash_completion.d/task > /dev/null"
  },
  "containerEnv": {
    "CLOUDEVENTS_CONFIG": "/workspaces/zigflow/cloudevents.example.yaml",
    "CONVERTER_KEY_PATH": "/workspaces/zigflow/keys.example.yaml",
    "GIT_REPO": "github.com/zigflow/zigflow",
    "LOG_LEVEL": "trace",
    "WORKFLOW_DIRECTORY": "/workspaces/zigflow/",
    "WORKFLOW_DIRECTORY_GLOB": "workflow.example.yaml",
    "ZIGGY_EXAMPLE_ENVVAR": "some-example-envvar"
  },
  "forwardPorts": [
    3000,
    5244,
    6277,
    7070,
    7233,
    8080,
    8233,
    9090,
    9999
  ]
}
